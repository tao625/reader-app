      {
        "name": "EntryAbility",
        "srcEntry": "./ets/EntryAbility.ets",
        "description": "阅读应用入口能力",
        "label": "$string:app_name",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ]
      }
    ],
    "requestPermissions": []
  }
}
